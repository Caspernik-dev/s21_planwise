# Database
DATABASE_URL=postgres://kc:kc_dev_pwd@localhost:5433/kc

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# GigaChat
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat
# GigaChat использует сертификаты «Минцифры РФ». Если в окружении нет корневого
# сертификата — выставить true. ВНИМАНИЕ: отключает проверку TLS НА ВЕСЬ ПРОЦЕСС
# (NODE_TLS_REJECT_UNAUTHORIZED=0), не только для GigaChat. Только dev/демо.
# Прод: поставить корневой сертификат через NODE_EXTRA_CA_CERTS и держать false.
GIGACHAT_INSECURE_TLS=false

# PII / RAG (для будущих планов)
PG_TSV_LANG=russian
SIMILARITY_THRESHOLD=0.78
MAX_GENERATIONS_PER_DAY=10
DEMO_USER_EMAILS=
