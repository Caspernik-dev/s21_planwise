# Database
# POSTGRES_PASSWORD используется docker-compose (пароль БД + интерполяция в DATABASE_URL).
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://kc:kc_dev_pwd@localhost:5433/kc

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# LLM. Провайдер выбирается через LLM_PROVIDER:
#   gigachat (по умолчанию) — внешний API Сбера, OAuth-авторизация.
#   openai                  — любой OpenAI-совместимый эндпоинт: локальная модель
#                             (Ollama / LM Studio / vLLM) ИЛИ OpenAI. Статический ключ.
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gigachat

# ── Режим A: GigaChat (LLM_PROVIDER=gigachat) ────────────────────────────────
# AUTH_KEY = base64(client_id:client_secret) из личного кабинета GigaChat.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat-2-Max
GIGACHAT_EMBED_MODEL=EmbeddingsGigaR
# GigaChat использует сертификаты «Минцифры РФ». В Docker-образе корневые серты
# вшиты (NODE_OPTIONS=--use-system-ca) — флаг ниже держать false.
# Только вне Docker и без NODE_EXTRA_CA_CERTS можно временно выставить true:
# ВНИМАНИЕ — отключает проверку TLS НА ВЕСЬ ПРОЦЕСС (NODE_TLS_REJECT_UNAUTHORIZED=0).
GIGACHAT_INSECURE_TLS=false

# ── Режим B: локальная / OpenAI-совместимая модель (LLM_PROVIDER=openai) ──────
# Раскомментировать и выставить LLM_PROVIDER=openai. base URL должен оканчиваться
# на /v1 (OpenAI-формат). Из Docker до хоста — host.docker.internal.
# LLM_API_BASE=http://host.docker.internal:11434/v1   # Ollama на хосте
# LLM_MODEL=llama3.1                                   # имя установленной модели
# LLM_API_KEY=ollama                                   # для Ollama годится любой непустой
# ⚠️ ЭМБЕДДИНГИ. Сменить чат-модель безопасно. Но колонки БД — vector(2560) под
# GigaChat EmbeddingsGigaR. Локальная embed-модель (напр. nomic-embed-text = 768)
# НЕ совпадёт по размерности → RAG/поиск/pre-match сломаются на INSERT. Полный
# офлайн требует: миграция размерности + пере-ingest корпуса локальной моделью.
# LLM_EMBED_MODEL=nomic-embed-text

# PII / RAG
PG_TSV_LANG=russian
SIMILARITY_THRESHOLD=0.78

# Лимиты (rate-limit). Генерация: MAX_GENERATIONS_PER_DAY в день на пользователя.
# DEMO_USER_EMAILS — список через запятую, эти аккаунты без лимита генераций (для жюри).
# Прочие лимиты зашиты в коде: login 5/15мин/IP, upload 20/день, export 100/день, search 60/мин.
MAX_GENERATIONS_PER_DAY=10
MAX_REGEN_PER_DAY=40
MAX_COPY_PER_DAY=50
MAX_PREMATCH_PER_DAY=60
DEMO_USER_EMAILS=

# Режим обслуживания: при MAINTENANCE_MODE=true доступ к /app/* открыт только
# для аккаунтов из MAINTENANCE_ALLOWLIST (через запятую) и для users.role='admin'.
# Лендинг, /login, /register, /changelog, /maintenance, /s/[token] остаются публичными.
# Включается правкой .env + `docker compose restart app` (~15 сек).
MAINTENANCE_MODE=false
MAINTENANCE_ALLOWLIST=

# Очередь к GigaChat. MAX_CONCURRENCY — сколько параллельных вызовов разрешено
# тарифом (текущий тариф = 1, новый = 5). Лишние запросы встают в FIFO до
# QUEUE_MAX; если очередь полна — 503. QUEUE_TIMEOUT_MS — сколько ждать слот.
GIGACHAT_MAX_CONCURRENCY=1
GIGACHAT_QUEUE_MAX=10
GIGACHAT_QUEUE_TIMEOUT_MS=300000

# RAG / Embeddings (embed-модель задаётся в LLM-блоке выше)
RAG_EMBED_BATCH=32
RAG_TOP_K=3
RAG_CANDIDATES=24
RAG_MAX_PER_DOC=2

# SMTP (email verification и password reset)
SMTP_HOST=mail.caspernik.ru
SMTP_PORT=465
SMTP_USER=planwise@caspernik.ru
SMTP_PASS=replace-me
EMAIL_FROM="Planwise <planwise@caspernik.ru>"
APP_URL=https://plan-wise.ru

# Опциональные пороги (с дефолтами)
VERIFY_TOKEN_TTL_SEC=86400
RESET_TOKEN_TTL_SEC=3600
PV_CHECK_INTERVAL_SEC=300
PV_CHECK_TIMEOUT_MS=2000
MAX_VERIFY_RESEND_PER_HOUR=3
MAX_FORGOT_PER_HOUR=5
MAX_RESET_ATTEMPT_PER_HOUR=10

# Пул postgres-js. max — параллельные коннекты; connect_timeout/idle_timeout — в секундах.
DATABASE_MAX_POOL=25
DATABASE_CONNECT_TIMEOUT_SEC=10
DATABASE_IDLE_TIMEOUT_SEC=30
